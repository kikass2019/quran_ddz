name: quran_sunnah_app
description: تطبيق القرآن والسنة - Quran & Sunnah App
publish_to: 'none'
version: 2.0.0+2

environment:
  sdk: '>=3.0.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter

  # Audio
  just_audio: ^0.10.5
  audio_session: ^0.2.3

  # HTTP
  http: ^1.1.0
  dio: ^5.4.0

  # State
  provider: ^6.1.1

  # Storage
  shared_preferences: ^2.2.2
  hive: ^2.2.3
  hive_flutter: ^1.1.0

  # UI
  flutter_svg: ^2.0.9
  cached_network_image: ^3.3.1
  shimmer: ^3.0.0
  google_fonts: ^6.2.1

  # Utils
  url_launcher: ^6.2.3
  connectivity_plus: ^7.1.1
  package_info_plus: ^8.3.0
  webview_flutter: ^4.4.2

dev_dependencies:
  flutter_test:
    sdk: flutter
  hive_generator: ^2.0.1
  build_runner: ^2.4.8
  flutter_lints: ^6.0.0

flutter:
  uses-material-design: true

  assets:
    - assets/images/

  # ⚠️ Fonts déclarées uniquement si les fichiers existent dans assets/fonts/
  # Pour utiliser Amiri et UthmanicHafs, placez les fichiers TTF dans :
  #   assets/fonts/Amiri-Regular.ttf
  #   assets/fonts/Amiri-Bold.ttf
  #   assets/fonts/UthmanicHafs_V22.ttf
  # Ou téléchargez-les depuis :
  #   Amiri        : https://fonts.google.com/specimen/Amiri
  #   UthmanicHafs : https://github.com/mustafa0x/qpc-fonts
  #
  # Si les fichiers sont absents, la section fonts doit rester commentée.
